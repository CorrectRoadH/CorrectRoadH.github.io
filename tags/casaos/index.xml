&lt;p&gt;&lt;img src=&#34;https://correctroadh.github.io/p/casaos-frontend-%E4%BC%98%E5%8C%96%E4%B8%8E%E9%87%8D%E6%9E%84%E7%BB%8F%E5%8E%86/4.png&#34;
